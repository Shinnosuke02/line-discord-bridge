# Minimal local example. For full documentation, see env.example.
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
PUBLIC_BASE_URL=https://your-domain.example

LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_WEBHOOK_PATH=/webhook

DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CLIENT_ID=

WEBHOOK_ENABLED=true
WEBHOOK_NAME=LINE Bridge
BRIDGE_REPLY_ENABLED=true
BRIDGE_REACTION_ENABLED=false
LINE_TO_DISCORD_REPLY_MODE=webhook

LINE_SIGNATURE_VALIDATION_ENABLED=true
TEMP_PATH=./temp
TEMP_STATIC_ENABLED=true
UPLOAD_PATH=./uploads

LOG_LEVEL=info
MESSAGE_BATCH_TIMEOUT=120000
MESSAGE_BATCH_MAX_SIZE=10
